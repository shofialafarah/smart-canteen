{
    "version": 2,
    "installCommand": "composer install",
    "buildCommand": "npm install && npm run build",
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.5"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "PHP_VERSION": "8.2"
    }
}